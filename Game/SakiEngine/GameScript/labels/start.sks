//label// SakiEngine 剧情标签脚本文件
label start
scene bg school 
yk pose2 happy "/zhs 欢迎来到SakiEngine！/ /zhc 歡迎來到SakiEngine！/ /en Welcome to SakiEngine!/ /jp SakiEngineへようこそ！/"
yk "/zhs 1111/ /zhc 1111/ /en 1111/ /jp 1111/"
menu
"/zhs 动画测试/ /zhc 動畫測試/ /en Animation Test/ /jp アニメーションテスト/" after_choice1
"/zhs 保持沉默/ /zhc 保持沉默/ /en Stay Silent/ /jp 黙っている/" after_choice2
"/zhs 表情测试/ /zhc 表情測試/ /en Expression Test/ /jp 表情テスト/" after_choice3
"/zhs 测试长句子/ /zhc 測試長句子/ /en Long Sentence Test/ /jp 長文テスト/" after_choice4
"/zhs 测试断句/ /zhc 測試斷句/ /en Sentence Break Test/ /jp 句読点テスト/" after_choice6
"/zhs 切换背景/ /zhc 切換背景/ /en Switch Background/ /jp 背景切り替え/" after_choice5
"/zhs 切换背景&&旁白/ /zhc 切換背景&&旁白/ /en Background && Narration/ /jp 背景&&ナレーション/" after_choice7
"/zhs 测试旁白模式/ /zhc 測試旁白模式/ /en NVL Mode Test/ /jp NVLモードテスト/" after_choice_nvl
"/zhs 测试电影旁白模式/ /zhc 測試電影旁白模式/ /en Cinematic NVL Test/ /jp シネマNVLモードテスト/" after_choice_nvlm
"/zhs 测试计时器/ /zhc 測試計時器/ /en Timer Test/ /jp タイマーテスト/" after_choice_timer
"/zhs 立绘测试/ /zhc 立繪測試/ /en Sprite Test/ /jp 立ち絵テスト/" after_choice8
endmenu
//就是这样，选择之后会跳转到after_choice1，after_choice2，after_choice3
label after_choice1
yk an jump "/zhs 这是跳。/ /zhc 這是跳躍。/ /en This is jump./ /jp これはジャンプです。/"
yk an shake "/zhs 这是抖动。/ /zhc 這是抖動。/ /en This is shake./ /jp これはシェイクです。/"
yk an bounce "/zhs 这是弹跳。/ /zhc 這是彈跳。/ /en This is bounce./ /jp これはバウンスです。/"
"/zhs 嘿嘿，喜欢吗？/ /zhc 嘿嘿，喜歡嗎？/ /en Hehe, do you like it?/ /jp えへへ、気に入った？/"
"/zhs 那我以后每天都给你带巧克力哦！/ /zhc 那我以後每天都給你帶巧克力喔！/ /en Then I'll bring you chocolate every day!/ /jp じゃあこれから毎日チョコを持ってくるね！/"
yk "/zhs 嗯嗯！/ /zhc 嗯嗯！/ /en Yep!/ /jp うん！/"
return

label after_choice2
yk sad "/zhs ……你怎么不说话？/ /zhc ……你怎麼不說話？/ /en ...Why aren't you speaking?/ /jp ……どうして黙ってるの？/"
yk "/zhs 不理你了。/ /zhc 不理你了。/ /en Fine, I'll ignore you./ /jp もう知らない。/"
yk happy "/zhs 哼，生气了。/ /zhc 哼，生氣了。/ /en Hmph, I'm mad./ /jp ふん、怒ったからね。/"
return 

label after_choice3
yk pose1 "/zhs 这是站姿。/ /zhc 這是站姿。/ /en This is standing pose./ /jp これは立ち姿です。/"
yk pose2 "/zhs 这是思考。/ /zhc 這是思考。/ /en This is thinking pose./ /jp これは考えるポーズです。/"
yk pose1 happy "/zhs 这是开心。/ /zhc 這是開心。/ /en This is happy./ /jp これは嬉しい表情です。/"
yk sad "/zhs 这是不好的表情。/ /zhc 這是不好的表情。/ /en This is a sad expression./ /jp これは悲しい表情です。/"
yk eye "/zhs 这是闭眼。/ /zhc 這是閉眼。/ /en This is closed eyes./ /jp これは目を閉じた表情です。/"
yk eye2 "/zhs 这是闭眼张嘴。/ /zhc 這是閉眼張嘴。/ /en This is closed eyes with open mouth./ /jp これは目を閉じて口を開けた表情です。/"
yk shy "/zhs 这是害羞。/ /zhc 這是害羞。/ /en This is shy./ /jp これは照れ顔です。/"
yk star "/zhs 这是星星眼。/ /zhc 這是星星眼。/ /en This is starry eyes./ /jp これは星目の表情です。/"
yk pose2 think "/zhs 这是思考。/ /zhc 這是思考。/ /en This is thinking./ /jp これは考え中です。/"
yk say "/zhs 这是说话。/ /zhc 這是說話。/ /en This is speaking./ /jp これは話している表情です。/"
return

